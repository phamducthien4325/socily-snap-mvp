# FalkorDB
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Email (Gmail) - Optional for sending emails
# Hướng dẫn lấy App Password:
# 1. Bật 2FA cho Gmail: https://myaccount.google.com/security
# 2. Tạo App Password: https://myaccount.google.com/apppasswords
# 3. Paste mã 16 ký tự vào EMAIL_PASS bên dưới
EMAIL_USER=your_email@gmail.com
EMAIL_PASS="your app password"

# Tên Graph trong FalkorDB
GRAPH_NAME=socily_snap
